        {
          "expr": "label_replace(max by (server) (haproxy_server_status{proxy=\"k8s-http\", state=\"UP\"}), \"node_name\", \"worker-0$1\", \"server\", \"node0(.)\")",
          "legendFormat": "{{node_name}} - k8s-http",
          "refId": "C"
        },
        {
          "expr": "haproxy_backend_status{state=\"UP\", node!=\"\"}",
          "legendFormat": "{{node}} - backend-{{proxy}}",
          "refId": "D"
